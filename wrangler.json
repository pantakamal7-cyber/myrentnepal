{
  "name": "myrentnepal",
  "compatibility_date": "2026-06-14",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "main": "server/index.ts",
  "build": {
    "command": "npm install --legacy-peer-deps && npm run build"
  },
  "assets": {
    "directory": "client/dist",
    "not_found_handling": "single-page-application",
    "binding": "ASSETS"
  }
}
